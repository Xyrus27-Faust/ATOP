# Base URL of the ATOP backend API (no trailing slash, no /api prefix).
# The dev API runs on http://localhost:5134 and serves auth routes under /auth.
VITE_API_BASE_URL=http://localhost:5134

# Google OAuth client ID for "Continue with Google". This value is public, but it
# is account-specific, so set the real one in .env.local (gitignored). It must
# match the backend's Authentication:Google:ClientId.
VITE_GOOGLE_CLIENT_ID=
