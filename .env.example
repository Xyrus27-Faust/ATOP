# Copy to .env and adjust as needed.
# Base URL of the ATOP backend API (no trailing slash, no /api prefix).
VITE_API_BASE_URL=http://localhost:5134

# Google OAuth client ID for "Continue with Google" (public; must match the
# backend's Authentication:Google:ClientId). Put the real value in .env.local.
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
